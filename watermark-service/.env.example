# FashionGuard Watermark Service Configuration

# Server Configuration
HOST=0.0.0.0
PORT=8000
DEBUG=false
LOG_LEVEL=INFO

# Node.js Backend Integration
NODEJS_BACKEND_URL=http://localhost:5000

# DCT Watermark Settings
DCT_BLOCK_SIZE=8
DCT_BASE_STRENGTH=25.0
DCT_MIN_STRENGTH=10.0
DCT_MAX_STRENGTH=50.0

# LSB Watermark Settings
LSB_BIT_DEPTH=2
LSB_MIN_TEXTURE_THRESHOLD=0.3

# Error Correction
RS_ERROR_SYMBOLS=32
REDUNDANCY_FACTOR=3

# Quality Targets
TARGET_PSNR=40.0
TARGET_SSIM=0.98
MIN_CONFIDENCE_THRESHOLD=0.7

# Limits
MAX_IMAGE_SIZE_MB=50
MAX_IMAGE_DIMENSION=8192

# AI Optimization
ENABLE_AI_OPTIMIZATION=true
